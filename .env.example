# Copy to .env and fill in. Provider is swappable; defaults to Anthropic.
LLM_PROVIDER=anthropic
# Global fallback model. claude-haiku-4-5-20251001 (fast/cheap),
# claude-sonnet-4-6 (balanced), claude-opus-4-8 (highest quality).
LLM_MODEL=claude-haiku-4-5-20251001
# Per-agent overrides (precedence: <ROLE>_MODEL > LLM_MODEL > built-in default).
# Routing quality matters most, so it runs on Sonnet; the rest stay on Haiku.
ROUTER_MODEL=claude-sonnet-4-6
# COACH_MODEL=claude-haiku-4-5-20251001
# GENERATOR_MODEL=claude-haiku-4-5-20251001
# LOGGER_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-...

# Router low-confidence threshold: below this -> CLARIFY route
ROUTER_CONFIDENCE_THRESHOLD=0.6

# CORS allowlist (comma-separated). Default "*". In prod set to the frontend URL.
ALLOWED_ORIGINS=*

# Shared secret the frontend must send as X-API-Key. Unset = check disabled.
# (Also accepted as ?api_key= for the EventSource stream.)
# API_KEY=
# Max /chat requests per client IP per minute (0 = disabled).
RATE_LIMIT_PER_MIN=30
# Durable conversation memory (sqlite path). Unset = in-process only.
# CHECKPOINT_DB=/data/memory.sqlite

# Observability (LangSmith). When enabled, LangChain auto-traces LLM calls and
# graph nodes; the @traced tools add nested tool spans.
LANGSMITH_API_KEY=lsv2_
LANGSMITH_TRACING=true
LANGCHAIN_PROJECT=fitness-coach-agents
