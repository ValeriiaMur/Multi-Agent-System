# Python
__pycache__/
*.pyc
.venv/
.env

# Sandbox/test install artifacts (safe to delete)
.pylibs/
.npm-cache/
.npm-tmp/
.tmp/

# Node
node_modules/
dist/
# Vite leaks these when bundling a TS config; never commit them
vite.config.ts.timestamp-*.mjs
vite.config.*.timestamp-*
# Compiled JS must never land next to TS sources (tsc has noEmit; Vite bundles).
# Guards against re-leaking if someone runs tsc without noEmit.
frontend/src/**/*.js
frontend/src/**/*.js.map
.env

# OS
.DS_Store
