# Copy to .env (local) or set in your host's build env (Railway/Vercel/etc).
#
# Base URL of the deployed backend. MUST be set at *build time* for the deployed
# frontend — Vite inlines it into the bundle. Leave UNSET for local dev: the Vite
# dev server proxies /chat and /feedback to http://localhost:8000 (see vite.config.ts).
#
# Example (Railway): VITE_API_BASE=https://your-backend.up.railway.app
VITE_API_BASE=
